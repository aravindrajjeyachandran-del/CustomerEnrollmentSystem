
@{ var apiBaseUrl = ViewBag.ApiBaseUrl as string ?? "https://localhost:7100"; }
@{
    ViewData["Title"] = "Enroll";

}

<h2>Customer Enroll</h2>

<form id="frm">
    <input type="text" id="name" placeholder="Name" /><br />
    <input type="text" id="mobile" placeholder="Mobile" /><br />
    <input type="text" id="email" placeholder="Email" /><br />

    <select id="proofType">
        <option>Aadhaar</option>
        <option>PAN</option>
        <option>Passport</option>
    </select><br />

    <input type="text" id="proofNumber" placeholder="Proof Number" /><br />
    <textarea id="address"></textarea><br />

    <button type="submit">Submit</button>
</form>

<script>
    async function enc(val) {
        if (!val) return "";

        let enc = new TextEncoder();
        const SECRET = "Enr0llment@SecretKey#2024!XyZ"; // match appsettings

        async function deriveKey(secret) {
            const raw = await crypto.subtle.importKey(
                "raw", new TextEncoder().encode(secret),
                { name: "PBKDF2" }, false, ["deriveKey"]
            );
            return crypto.subtle.deriveKey(
                {
                    name: "PBKDF2", salt: new TextEncoder().encode("EnrollSalt"),
                    iterations: 100000, hash: "SHA-256"
                },
                raw, { name: "AES-CBC", length: 256 }, false, ["encrypt"]
            );
        }

        async function encryptField(key, text) {
            const iv = crypto.getRandomValues(new Uint8Array(16)); // random per field!
            const cipher = await crypto.subtle.encrypt(
                { name: "AES-CBC", iv }, key, new TextEncoder().encode(text)
            );
            const out = new Uint8Array(16 + cipher.byteLength);
            out.set(iv); out.set(new Uint8Array(cipher), 16); // prepend IV
            return btoa(String.fromCharCode(...out));
        }

        return btoa(String.fromCharCode(...new Uint8Array(encrypted)));
    }

    document.getElementById("frm").addEventListener("submit", async function (e) {
        e.preventDefault();

        let data = {
            name: await enc(name.value),
            mobile: await enc(mobile.value),
            email: await enc(email.value),
            proofType: await enc(proofType.value),
            proofNumber: await enc(proofNumber.value),
            address: await enc(address.value)
        };

        let res = await fetch("https://localhost:5001/api/customer/enroll", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        });

        let result = await res.json();
        alert("Saved. ID: " + result.customerId);
    });
</script>