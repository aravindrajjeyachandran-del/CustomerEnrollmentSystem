@{
    ViewData["Title"] = "Enroll";
}

<h2>Customer Enroll</h2>

<form id="frm">
    <input type="text" id="name" placeholder="Name" /><br />
    <input type="text" id="mobile" placeholder="Mobile" /><br />
    <input type="text" id="email" placeholder="Email" /><br />

    <select id="proofType">
        <option>Aadhaar</option>
        <option>PAN</option>
        <option>Passport</option>
    </select><br />

    <input type="text" id="proofNumber" placeholder="Proof Number" /><br />
    <textarea id="address"></textarea><br />

    <button type="submit">Submit</button>
</form>

<script>
    async function enc(val) {
        if (!val) return "";

        let enc = new TextEncoder();
        let key = await crypto.subtle.importKey(
            "raw",
            enc.encode("12345678901234567890123456789012"),
            { name: "AES-CBC" },
            false,
            ["encrypt"]
        );

        let iv = enc.encode("1234567890123456");

        let encrypted = await crypto.subtle.encrypt(
            { name: "AES-CBC", iv: iv },
            key,
            enc.encode(val)
        );

        return btoa(String.fromCharCode(...new Uint8Array(encrypted)));
    }

    document.getElementById("frm").addEventListener("submit", async function (e) {
        e.preventDefault();

        let data = {
            name: await enc(name.value),
            mobile: await enc(mobile.value),
            email: await enc(email.value),
            proofType: await enc(proofType.value),
            proofNumber: await enc(proofNumber.value),
            address: await enc(address.value)
        };

        let res = await fetch("https://localhost:5001/api/customer/enroll", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        });

        let result = await res.json();
        alert("Saved. ID: " + result.customerId);
    });
</script>